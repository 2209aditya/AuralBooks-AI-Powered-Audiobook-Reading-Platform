<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>AuralBooks — AI-Powered Audiobook & Reading Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,900;1,400;1,600&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style>
/* ─── TOKENS ─────────────────────────────────────────── */
:root {
  --ink: #0d0c0a;
  --paper: #f5f0e8;
  --amber: #d4860a;
  --amber-light: #f0a830;
  --amber-glow: rgba(212,134,10,0.18);
  --cream: #ede8dc;
  --muted: #6b6557;
  --border: rgba(212,134,10,0.25);
  --glass: rgba(13,12,10,0.55);
  --white: #fff;
  --ff-display: 'Playfair Display', Georgia, serif;
  --ff-body: 'DM Sans', sans-serif;
  --ff-mono: 'DM Mono', monospace;
}

/* ─── RESET ──────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--ink);
  color: var(--paper);
  font-family: var(--ff-body);
  font-weight: 300;
  overflow-x: hidden;
  cursor: none;
}

/* ─── CUSTOM CURSOR ──────────────────────────────────── */
.cursor {
  position: fixed;
  width: 10px; height: 10px;
  background: var(--amber);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%, -50%);
  transition: transform 0.08s, width 0.2s, height 0.2s, opacity 0.2s;
  mix-blend-mode: normal;
}
.cursor-ring {
  position: fixed;
  width: 36px; height: 36px;
  border: 1.5px solid var(--amber);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9998;
  transform: translate(-50%, -50%);
  transition: transform 0.18s ease, width 0.3s, height 0.3s, opacity 0.3s;
  opacity: 0.5;
}
body:hover .cursor { opacity: 1; }

/* ─── NOISE OVERLAY ──────────────────────────────────── */
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 1;
  opacity: 0.5;
}

/* ─── NAV ────────────────────────────────────────────── */
nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.5rem 3rem;
  border-bottom: 1px solid transparent;
  transition: border-color 0.4s, background 0.4s, backdrop-filter 0.4s;
}
nav.scrolled {
  background: rgba(13,12,10,0.85);
  backdrop-filter: blur(18px);
  border-color: var(--border);
}
.nav-logo {
  display: flex; align-items: center; gap: 0.6rem;
  text-decoration: none;
}
.logo-mark {
  width: 34px; height: 34px;
  border: 1.5px solid var(--amber);
  border-radius: 4px;
  display: flex; align-items: center; justify-content: center;
  position: relative;
}
.logo-mark::after {
  content: '';
  width: 14px; height: 14px;
  border-radius: 50%;
  background: var(--amber);
  box-shadow: 0 0 14px var(--amber-light);
}
.logo-text {
  font-family: var(--ff-display);
  font-size: 1.2rem;
  font-weight: 600;
  letter-spacing: -0.02em;
  color: var(--paper);
}
.logo-text span { color: var(--amber); }
.nav-links {
  display: flex; align-items: center; gap: 2.5rem;
  list-style: none;
}
.nav-links a {
  text-decoration: none;
  color: var(--muted);
  font-size: 0.85rem;
  font-weight: 400;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--paper); }
.nav-cta {
  display: flex; gap: 1rem;
}
.btn-ghost {
  padding: 0.55rem 1.4rem;
  border: 1px solid var(--border);
  border-radius: 2px;
  background: transparent;
  color: var(--paper);
  font-family: var(--ff-body);
  font-size: 0.82rem;
  font-weight: 400;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  cursor: none;
  transition: border-color 0.2s, color 0.2s;
}
.btn-ghost:hover { border-color: var(--amber); color: var(--amber); }
.btn-primary {
  padding: 0.55rem 1.6rem;
  background: var(--amber);
  border: 1px solid var(--amber);
  border-radius: 2px;
  color: var(--ink);
  font-family: var(--ff-body);
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  cursor: none;
  transition: background 0.2s, box-shadow 0.2s;
}
.btn-primary:hover {
  background: var(--amber-light);
  box-shadow: 0 0 28px var(--amber-glow);
}

/* ─── HERO ───────────────────────────────────────────── */
.hero {
  position: relative;
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 65% 50%, rgba(212,134,10,0.12) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 20% 80%, rgba(212,134,10,0.06) 0%, transparent 60%),
    linear-gradient(165deg, #0d0c0a 0%, #171510 60%, #0d0c0a 100%);
}
/* Subtle grid lines */
.hero-bg::after {
  content: '';
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(212,134,10,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(212,134,10,0.04) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse at 60% 50%, black 20%, transparent 70%);
}

.hero-left {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 10rem 4rem 6rem 5rem;
}
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 0.7rem;
  margin-bottom: 2rem;
  opacity: 0;
  animation: fadeUp 0.8s 0.2s forwards;
}
.eyebrow-dot {
  width: 6px; height: 6px;
  background: var(--amber);
  border-radius: 50%;
  box-shadow: 0 0 8px var(--amber);
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%,100% { box-shadow: 0 0 4px var(--amber); }
  50% { box-shadow: 0 0 14px var(--amber-light); }
}
.eyebrow-text {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--amber);
}
.hero-title {
  font-family: var(--ff-display);
  font-size: clamp(3rem, 5.5vw, 5.5rem);
  font-weight: 900;
  line-height: 1.02;
  letter-spacing: -0.025em;
  margin-bottom: 1.8rem;
  opacity: 0;
  animation: fadeUp 0.9s 0.35s forwards;
}
.hero-title em {
  font-style: italic;
  color: var(--amber);
}
.hero-title .outline {
  -webkit-text-stroke: 1.5px var(--paper);
  color: transparent;
}
.hero-desc {
  font-size: 1.05rem;
  line-height: 1.7;
  color: var(--muted);
  max-width: 440px;
  margin-bottom: 2.8rem;
  opacity: 0;
  animation: fadeUp 0.9s 0.5s forwards;
}
.hero-actions {
  display: flex; align-items: center; gap: 1.5rem;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.9s 0.65s forwards;
}
.btn-large {
  padding: 0.9rem 2.2rem;
  font-size: 0.9rem;
}
.hero-sub {
  display: flex; align-items: center; gap: 0.6rem;
  font-size: 0.78rem;
  color: var(--muted);
  letter-spacing: 0.04em;
}
.hero-sub svg { width: 14px; height: 14px; color: var(--amber); }

.hero-stats {
  display: flex; gap: 3rem;
  margin-top: 4rem;
  padding-top: 2.5rem;
  border-top: 1px solid rgba(255,255,255,0.07);
  opacity: 0;
  animation: fadeUp 0.9s 0.8s forwards;
}
.stat-item { display: flex; flex-direction: column; gap: 0.3rem; }
.stat-num {
  font-family: var(--ff-display);
  font-size: 1.9rem;
  font-weight: 600;
  color: var(--paper);
  line-height: 1;
}
.stat-num span { color: var(--amber); font-style: italic; }
.stat-label {
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
}

/* ─── HERO RIGHT — Book Visual ───────────────────────── */
.hero-right {
  position: relative; z-index: 2;
  display: flex; align-items: center; justify-content: center;
  padding: 8rem 3rem 6rem;
  opacity: 0;
  animation: fadeIn 1.2s 0.6s forwards;
}
.book-showcase {
  position: relative;
  width: 340px; height: 480px;
}
/* Main book card */
.book-card {
  position: absolute;
  width: 240px;
  border-radius: 6px;
  overflow: hidden;
  box-shadow:
    0 40px 80px rgba(0,0,0,0.7),
    0 0 0 1px rgba(212,134,10,0.15),
    inset 0 1px 0 rgba(255,255,255,0.07);
  transform: rotate(-4deg);
  top: 30px; left: 20px;
  transition: transform 0.6s cubic-bezier(0.23,1,0.32,1);
}
.book-card:hover { transform: rotate(0deg) translateY(-8px); }
.book-cover {
  width: 100%; height: 340px;
  background: linear-gradient(145deg, #1a2535 0%, #0d1520 60%, #1a1008 100%);
  position: relative;
  overflow: hidden;
  display: flex; flex-direction: column; justify-content: flex-end;
  padding: 1.5rem;
}
.book-cover::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 200px;
  background: radial-gradient(ellipse at 70% 30%, rgba(212,134,10,0.25), transparent 60%);
}
.book-spine {
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 14px;
  background: linear-gradient(180deg, #b3720a, #7a4c06);
  border-right: 1px solid rgba(255,255,255,0.1);
}
.book-cover-title {
  font-family: var(--ff-display);
  font-size: 1.3rem;
  font-weight: 700;
  line-height: 1.2;
  color: var(--paper);
  position: relative; z-index: 1;
  margin-bottom: 0.4rem;
}
.book-cover-author {
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(245,240,232,0.55);
  position: relative; z-index: 1;
}
.book-cover-deco {
  position: absolute;
  top: 1.5rem; right: 1.5rem;
  width: 48px; height: 48px;
  border: 1px solid rgba(212,134,10,0.4);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: var(--amber);
  font-size: 1.3rem;
}
.book-meta {
  background: #161410;
  padding: 1rem 1.4rem;
  display: flex; align-items: center; justify-content: space-between;
}
.book-rating {
  display: flex; align-items: center; gap: 0.4rem;
  font-size: 0.78rem; color: var(--paper);
}
.stars { color: var(--amber); font-size: 0.7rem; letter-spacing: 0.05em; }
.ai-badge {
  display: flex; align-items: center; gap: 0.4rem;
  background: var(--amber-glow);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 0.25rem 0.7rem;
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--amber);
}

/* Audio player card */
.audio-card {
  position: absolute;
  right: -10px; bottom: 20px;
  width: 220px;
  background: rgba(20,18,14,0.92);
  backdrop-filter: blur(20px);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1rem 1.2rem;
  box-shadow: 0 20px 50px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.04);
  animation: floatCard 4s ease-in-out infinite;
}
@keyframes floatCard {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}
.audio-card-label {
  font-size: 0.6rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.7rem;
}
.audio-card-title {
  font-family: var(--ff-display);
  font-size: 0.9rem;
  margin-bottom: 0.25rem;
  color: var(--paper);
}
.audio-card-voice {
  font-size: 0.68rem;
  color: var(--muted);
  margin-bottom: 1rem;
}
.audio-wave {
  display: flex; align-items: center; gap: 2px;
  height: 28px; margin-bottom: 0.9rem;
}
.wave-bar {
  width: 3px;
  background: var(--amber);
  border-radius: 10px;
  animation: waveAnim 1.2s ease-in-out infinite;
}
.wave-bar:nth-child(1) { height: 8px; animation-delay: 0s; }
.wave-bar:nth-child(2) { height: 20px; animation-delay: 0.1s; }
.wave-bar:nth-child(3) { height: 14px; animation-delay: 0.2s; }
.wave-bar:nth-child(4) { height: 24px; animation-delay: 0.3s; }
.wave-bar:nth-child(5) { height: 18px; animation-delay: 0.4s; }
.wave-bar:nth-child(6) { height: 10px; animation-delay: 0.5s; }
.wave-bar:nth-child(7) { height: 22px; animation-delay: 0.35s; }
.wave-bar:nth-child(8) { height: 16px; animation-delay: 0.15s; }
.wave-bar:nth-child(9) { height: 12px; animation-delay: 0.25s; }
.wave-bar:nth-child(10) { height: 20px; animation-delay: 0.45s; }
.wave-bar:nth-child(11) { height: 8px; animation-delay: 0.55s; }
.wave-bar:nth-child(12) { height: 18px; animation-delay: 0.05s; }
@keyframes waveAnim {
  0%,100% { transform: scaleY(0.5); opacity: 0.6; }
  50% { transform: scaleY(1); opacity: 1; }
}
.audio-controls {
  display: flex; align-items: center; justify-content: space-between;
}
.play-btn {
  width: 32px; height: 32px;
  background: var(--amber);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: none;
}
.play-btn svg { width: 12px; height: 12px; fill: var(--ink); margin-left: 2px; }
.speed-badge {
  font-family: var(--ff-mono);
  font-size: 0.7rem;
  color: var(--muted);
  background: rgba(255,255,255,0.05);
  padding: 0.2rem 0.5rem;
  border-radius: 3px;
}
.audio-progress {
  display: flex; align-items: center; gap: 0.5rem;
  margin-top: 0.8rem;
}
.progress-track {
  flex: 1; height: 2px;
  background: rgba(255,255,255,0.1);
  border-radius: 2px;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  width: 38%;
  background: linear-gradient(90deg, var(--amber), var(--amber-light));
  border-radius: 2px;
}
.progress-time {
  font-family: var(--ff-mono);
  font-size: 0.6rem;
  color: var(--muted);
}

/* AI chat card */
.ai-card {
  position: absolute;
  top: 0; right: 20px;
  width: 180px;
  background: rgba(20,18,14,0.92);
  backdrop-filter: blur(20px);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0.9rem 1rem;
  box-shadow: 0 12px 30px rgba(0,0,0,0.5);
  animation: floatCard 5s 1s ease-in-out infinite;
}
.ai-card-header {
  display: flex; align-items: center; gap: 0.5rem;
  margin-bottom: 0.7rem;
}
.ai-avatar {
  width: 22px; height: 22px;
  background: linear-gradient(135deg, var(--amber), #c06800);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.6rem;
}
.ai-name { font-size: 0.7rem; font-weight: 500; color: var(--paper); }
.ai-msg {
  font-size: 0.68rem;
  line-height: 1.5;
  color: var(--muted);
  background: rgba(255,255,255,0.04);
  border-radius: 6px;
  padding: 0.6rem 0.7rem;
  border-left: 2px solid var(--amber);
}

/* ─── SCROLL INDICATOR ───────────────────────────────── */
.scroll-hint {
  position: absolute;
  bottom: 2.5rem; left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 0.6rem;
  z-index: 10;
  opacity: 0;
  animation: fadeIn 1s 1.4s forwards;
}
.scroll-hint span {
  font-size: 0.65rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--muted);
}
.scroll-line {
  width: 1px; height: 50px;
  background: linear-gradient(180deg, var(--amber) 0%, transparent 100%);
  animation: scrollDown 2s ease-in-out infinite;
}
@keyframes scrollDown {
  0% { transform: scaleY(0); transform-origin: top; }
  50% { transform: scaleY(1); transform-origin: top; }
  51% { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}

/* ─── FEATURES SECTION ───────────────────────────────── */
.section { position: relative; z-index: 2; padding: 8rem 5rem; }
.section-inner { max-width: 1280px; margin: 0 auto; }
.section-tag {
  display: inline-flex; align-items: center; gap: 0.6rem;
  margin-bottom: 1.2rem;
}
.tag-line {
  width: 32px; height: 1px;
  background: var(--amber);
}
.tag-label {
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--amber);
}
.section-title {
  font-family: var(--ff-display);
  font-size: clamp(2rem, 3.5vw, 3.4rem);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 1rem;
}
.section-subtitle {
  font-size: 1rem;
  line-height: 1.7;
  color: var(--muted);
  max-width: 520px;
  margin-bottom: 4rem;
}

/* Feature grid */
.feature-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5px;
  background: var(--border);
  border: 1px solid var(--border);
}
.feature-cell {
  background: var(--ink);
  padding: 2.5rem 2rem;
  position: relative;
  overflow: hidden;
  transition: background 0.3s;
}
.feature-cell::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 0% 100%, var(--amber-glow) 0%, transparent 60%);
  opacity: 0;
  transition: opacity 0.4s;
}
.feature-cell:hover { background: #111008; }
.feature-cell:hover::before { opacity: 1; }
.feature-icon {
  width: 44px; height: 44px;
  border: 1px solid var(--border);
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1.5rem;
  font-size: 1.2rem;
  position: relative; z-index: 1;
  background: rgba(212,134,10,0.07);
  transition: border-color 0.3s, background 0.3s;
}
.feature-cell:hover .feature-icon {
  border-color: var(--amber);
  background: var(--amber-glow);
}
.feature-name {
  font-family: var(--ff-display);
  font-size: 1.1rem;
  font-weight: 600;
  margin-bottom: 0.6rem;
  position: relative; z-index: 1;
  transition: color 0.3s;
}
.feature-cell:hover .feature-name { color: var(--amber); }
.feature-desc {
  font-size: 0.84rem;
  line-height: 1.65;
  color: var(--muted);
  position: relative; z-index: 1;
}
.feature-tag {
  display: inline-block;
  margin-top: 1rem;
  font-family: var(--ff-mono);
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--amber);
  background: var(--amber-glow);
  border: 1px solid rgba(212,134,10,0.2);
  border-radius: 2px;
  padding: 0.2rem 0.5rem;
  position: relative; z-index: 1;
}

/* ─── HOW IT WORKS ───────────────────────────────────── */
.hiw-section {
  padding: 8rem 5rem;
  background: #0a0908;
  position: relative;
  z-index: 2;
}
.hiw-grid {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 6rem;
  align-items: center;
  max-width: 1280px;
  margin: 0 auto;
}
.hiw-steps {
  display: flex; flex-direction: column; gap: 0;
}
.step {
  display: flex; gap: 1.5rem;
  padding: 2rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  position: relative;
  cursor: default;
}
.step:last-child { border-bottom: none; }
.step-num {
  font-family: var(--ff-display);
  font-size: 2.5rem;
  font-weight: 900;
  color: rgba(212,134,10,0.15);
  line-height: 1;
  min-width: 50px;
  transition: color 0.3s;
}
.step:hover .step-num { color: var(--amber); }
.step-content { flex: 1; }
.step-title {
  font-family: var(--ff-display);
  font-size: 1.05rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
  transition: color 0.3s;
}
.step:hover .step-title { color: var(--amber); }
.step-text {
  font-size: 0.84rem;
  line-height: 1.65;
  color: var(--muted);
}

